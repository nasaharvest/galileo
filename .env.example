# Copernicus Data Space Ecosystem Credentials
# Get free account at: https://dataspace.copernicus.eu/

# Required: Your account credentials for OData catalog and download APIs
COPERNICUS_USERNAME=your_email_or_username_here
COPERNICUS_PASSWORD=your_password_here

# Optional: OAuth client credentials for Sentinel Hub APIs
# Create at: https://shapps.dataspace.copernicus.eu/dashboard/#/account/settings
COPERNICUS_CLIENT_ID=your_client_id_here
COPERNICUS_CLIENT_SECRET=your_client_secret_here
